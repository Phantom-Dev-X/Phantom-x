# Copy this file to .env and fill in your values
# (Only needed on non-Replit platforms like Render, Railway, VPS, or local machine)
# Replit users: use the Secrets tab instead

# Required — get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Required for owner-only commands (setwelcome, setwelcomepic, previewwelcome)
# Get your Telegram ID by messaging @userinfobot on Telegram
OWNER_TELEGRAM_ID=your_telegram_user_id_here

# Optional — get from https://aistudio.google.com/ for AI commands (.ai / .gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — port for the keep-alive server (default: 3000)
# PORT=3000
